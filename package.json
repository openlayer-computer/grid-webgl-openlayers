{
  "name": "grid-webgl-openlayers",
  "version": "1.0.1",
  "description": "OpenLayers + WebGL grid choropleth and value labels for array grid JSON data",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./style.css": "./dist/grid-webgl-openlayers.css"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "npm run prepare:demo-data && vite",
    "build": "npm run build:lib",
    "build:lib": "vite build --mode lib",
    "prepublishOnly": "npm run build:lib",
    "prepare:demo-data": "node scripts/prepare-demo-data.mjs",
    "prebuild:demo": "npm run prepare:demo-data",
    "build:demo": "vite build --mode demo",
    "preview:demo": "vite preview --outDir dist-demo"
  },
  "peerDependencies": {
    "ol": "^9.0.0 || ^10.0.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@mapbox/tiny-sdf": "^2.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "ol": "^10.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0",
    "vue": "^3.5.13"
  },
  "keywords": [
    "webgl",
    "openlayers",
    "grid",
    "choropleth",
    "vue",
    "weather"
  ],
  "license": "MIT"
}
